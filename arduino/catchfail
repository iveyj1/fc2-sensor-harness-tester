#!/usr/bin/env bash

tty="/dev/ttyUSB0"

stty -F "$tty" 115200 raw -echo

exec 3<"$tty"

# Opening the serial port may reset the Nano once; let it boot.
sleep 2
count=0
while IFS= read -r line <&3; do
    # printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$line"
    printf '%s\n' "$line"
    if [[ "${line,,}" == *unit\ fail* ]]; then
        ((count++))
    fi
    if [[ "${line,,}" == *unit* ]]; then
        printf "fail count %d" "$count"
    fi
done

for i in {1..10}; do
    IFS= read -r line <&3 || break
    printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$line"
done

exec 3<&-
